{
  "id": "db-inventory",
  "source": "config",
  "run": [
    {
      "type": "db-inventory",
      "metric-prefix": "db_inventory",
      "include-columns": true,
      "include-indexes": true,
      "include-options": true,
      "table_prefixes": ["jetpack", "jp_", "jpsq_"],
      "option_names": ["jetpack_active_modules", "jetpack_options", "jetpack_private_options", "jetpack_sync_settings", "jpsq_sync_checkout"],
      "option_prefixes": ["jetpack_", "jpsq_"],
      "module_inventory": {
        "option": "jetpack_active_modules",
        "expected_modules": ["stats", "publicize", "related-posts", "markdown", "shortcodes", "widget-visibility"],
        "connection_dependent_modules": ["publicize", "stats"]
      }
    }
  ],
  "metadata": {
    "runner": "wp-codebox",
    "workload": "db-inventory",
    "coverage_shape": "Jetpack fixture database table, option, module-state, row, column, and index inventory",
    "manifest": "manifests/full-surface-coverage.json"
  }
}
