{
  "id": "studio-bfb",
  "description": "Local Studio Static Site Importer playground. Builds the hacked Studio CLI that honors STUDIO_STATIC_SITE_IMPORTER_PLUGIN_PATH and stops any stale Studio daemon so local `studio wp`/CLI runs use the importer substrate. Local play rig only; not a PR shape.",
  "components": {
    "studio": {
      "path": "~/Developer/studio@bfb-mu-plugin-agent-output",
      "branch": "bfb-mu-plugin-agent-output",
      "extensions": {
        "nodejs": {
          "studio_bench_variant": "bfb",
          "studio_static_site_importer_plugin_path": "~/Developer/static-site-importer"
        }
      }
    },
    "static-site-importer": {
      "path": "~/Developer/static-site-importer",
      "branch": "main"
    }
  },
  "services": {
    "studio-daemon": {
      "kind": "external",
      "discover": {
        "pattern": "wordpress-server-child.mjs"
      }
    }
  },
  "resources": {
    "exclusive": [
      "studio-agent-bfb-bench"
    ],
    "paths": [
      "${components.studio.path}",
      "${components.static-site-importer.path}"
    ],
    "process_patterns": [
      "wordpress-server-child.mjs"
    ]
  },
  "bench": {
    "default_component": "studio",
    "default_baseline_rig": "studio-agent-sdk"
  },
  "bench_workloads": {
    "nodejs": [
      "${package.root}/bench/studio-agent-runtime.bench.mjs",
      "${package.root}/bench/studio-agent-site-build.bench.mjs"
    ]
  },
  "pipeline": {
    "check": [
      {
        "kind": "check",
        "label": "Studio experiment worktree exists",
        "file": "${components.studio.path}/apps/cli/ai/system-prompt.ts"
      },
      {
        "kind": "check",
        "label": "Static Site Importer has Composer autoload",
        "file": "${components.static-site-importer.path}/vendor/autoload.php"
      },
      {
        "kind": "check",
        "label": "Static Site Importer CLI command is present",
        "file": "${components.static-site-importer.path}/includes/class-static-site-importer-cli-command.php",
        "contains": "import-theme"
      },
      {
        "kind": "check",
        "label": "Studio Static Site Importer env hook is present",
        "file": "${components.studio.path}/tools/common/lib/mu-plugins.ts",
        "contains": "STUDIO_STATIC_SITE_IMPORTER_PLUGIN_PATH"
      },
      {
        "kind": "check",
        "label": "Studio prompt documents Static Site Importer workflow",
        "file": "${components.studio.path}/apps/cli/ai/system-prompt.ts",
        "contains": "static-site-importer import-theme"
      },
      {
        "kind": "check",
        "label": "Static HTML import generates block theme",
        "command": "STUDIO_STATIC_SITE_IMPORTER_PLUGIN_PATH=${components.static-site-importer.path} /Users/chubes/.nvm/versions/node/v24.13.1/bin/node ${components.studio.path}/apps/cli/scripts/studio-bfb-smoke.mjs",
        "expect_exit": 0
      }
    ],
    "up": [
      {
        "kind": "command",
        "label": "npm install Studio experiment worktree",
        "command": "/Users/chubes/.nvm/versions/node/v24.13.1/bin/npm install",
        "cwd": "${components.studio.path}"
      },
      {
        "kind": "command",
        "label": "Build Studio CLI experiment worktree",
        "command": "/Users/chubes/.nvm/versions/node/v24.13.1/bin/npm run build",
        "cwd": "${components.studio.path}/apps/cli"
      },
      {
        "kind": "service",
        "id": "studio-daemon",
        "op": "stop"
      }
    ],
    "down": [
      {
        "kind": "service",
        "id": "studio-daemon",
        "op": "stop"
      }
    ]
  }
}
