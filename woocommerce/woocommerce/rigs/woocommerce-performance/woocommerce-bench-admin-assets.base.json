{
  "extends": "./woocommerce-fuzz-catalog.base.json",
  "bench_workloads": {
    "wordpress": {
      "$append": [
        {
          "path": "${package.root}/bench/checkout-shortcode-place-order-latency.php"
        },
        {
          "path": "${package.root}/bench/admin-dashboard-physical-products-query.php"
        }
      ]
    }
  },
  "bench_profiles": {
    "smoke": {
      "$append": [
        "checkout-shortcode-place-order-latency",
        "admin-dashboard-physical-products-query"
      ]
    },
    "hot": {
      "$append": [
        "checkout-shortcode-place-order-latency",
        "admin-dashboard-physical-products-query"
      ]
    }
  },
  "pipeline": {
    "check": {
      "$append": [
        {
          "kind": "requirement",
          "label": "WooCommerce admin script asset registry exists",
          "file": "${components.woocommerce.path}/plugins/woocommerce/assets/client/admin/wp-admin-scripts/command-palette.asset.php",
          "remediation": "Use a packaged WooCommerce checkout with generated admin assets before running admin scenarios."
        }
      ]
    }
  }
}
