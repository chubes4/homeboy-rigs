        "collect": [
          {
            "artifact": "raw_result"
          }
        ]
      }
    }
  ],
  "limits": {
    "max_cases": 25,
    "max_duration_seconds": 900
  },
  "coverage": {
    "surface_ids": [
      "woocommerce-layered-nav-widget",
      "woocommerce-product-archive"
