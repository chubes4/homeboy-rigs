{
  "schema": "homeboy/fuzz-workload/v1",
  "id": "frontend-rendering-request-coverage",
  "label": "WooCommerce frontend rendering and request coverage",
  "safety_class": "read_only",
  "surface_ids": [
    "woocommerce-shop-frontend",
    "woocommerce-product-frontend",
    "woocommerce-cart-checkout-frontend",
    "browser-requests"
  ],
  "operations": [
    "frontend-page-render",
    "asset-request-capture",
    "xhr-fetch-capture",
    "skipped-destructive-action-classification"
  ],
  "case_budget": 80,
  "duration_budget_seconds": 900,
  "metadata": {
    "kind": "wordpress-plugin-fuzz",
    "wordpress_runner": "wp-codebox",
    "workload_path": "${package.root}/bench/woocommerce-browser-coverage.trace.mjs",
    "expected_artifact_role": "fuzz_report",
    "expected_artifact_semantic_key": "fuzz.report",
    "fixture": {
      "runtime": "wp-codebox",
      "scope": "disposable-wordpress",
      "component": "woocommerce",
      "activation": "woocommerce/woocommerce.php"
    }
  },
  "target": {
    "type": "wordpress-plugin",
    "slug": "woocommerce",
    "component": "woocommerce"
  },
  "workload": {
    "runner": "wp-codebox",
    "type": "json",
    "path": "${package.root}/bench/woocommerce-browser-coverage.trace.mjs",
    "entry": "frontend-rendering-request-coverage"
  },
  "cases": [
    {
      "case_id": "frontend-rendering-request-coverage:default",
      "surface_ids": [
        "woocommerce-shop-frontend",
        "woocommerce-product-frontend",
        "woocommerce-cart-checkout-frontend",
        "browser-requests"
      ],
      "operations": [
        "frontend-page-render",
        "asset-request-capture",
        "xhr-fetch-capture",
        "skipped-destructive-action-classification"
      ],
      "phases": {
        "setup": [
          {
            "command": "wordpress.ensure-plugin-active",
            "args": [
              "plugin=woocommerce/woocommerce.php"
            ]
          }
        ],
        "action": [
          {
            "command": "wordpress.run-workload",
            "args": [
              "path=${package.root}/bench/woocommerce-browser-coverage.trace.mjs",
              "type=trace",
              "surface=frontend"
            ]
          }
        ],
        "assert": [
          {
            "command": "wordpress.collect-workload-result",
            "args": [
              "artifact=frontend_rendering_request_coverage"
            ]
          }
        ]
      },
      "artifacts": [
        {
          "name": "frontend_rendering_request_coverage",
          "path": "frontend-rendering-request-coverage/frontend_rendering_request_coverage.json",
          "required": true,
          "metadata": {
            "semantic_key": "fuzz.report"
          }
        }
      ],
      "metadata": {
        "safety_class": "read_only"
      }
    }
  ],
  "limits": {
    "max_cases": 80,
    "max_duration_seconds": 900
  },
  "coverage": {
    "surface_ids": [
      "woocommerce-shop-frontend",
      "woocommerce-product-frontend",
      "woocommerce-cart-checkout-frontend",
      "browser-requests"
    ],
    "operations": [
      "frontend-page-render",
      "asset-request-capture",
      "xhr-fetch-capture",
      "skipped-destructive-action-classification"
    ]
  },
  "proof_contracts": [
    {
      "id": "shop-product-cart-checkout-rendering-requests",
      "description": "Artifact must cover shop, product, cart, and checkout render requests, captured assets, XHR/fetch requests, and skipped destructive action reason codes.",
      "required_artifact": "frontend_rendering_request_coverage",
      "required_surfaces": [
        "shop",
        "product",
        "cart",
        "checkout"
      ]
    }
  ],
  "artifacts": {
    "expected": [
      {
        "name": "frontend_rendering_request_coverage",
        "role": "fuzz_report",
        "semantic_key": "fuzz.report",
        "required": true
      }
    ]
  }
}
