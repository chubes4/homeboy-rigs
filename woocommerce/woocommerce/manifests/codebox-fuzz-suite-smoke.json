        "wordpress.inventory-database",
        "wordpress.attribute-rest-schema-queries",
        "wordpress.summarize-performance-hotspots",
        "wordpress.coverage-gap-report"
      ],
      "source_manifests": [
        "fuzz/woocommerce-rest-route-inventory.json",
