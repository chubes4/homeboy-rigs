{
  "schema": "homeboy/fuzz-workload/v1",
  "id": "content-types-taxonomies",
  "label": "WordPress Core post type, status, taxonomy, term, and permalink coverage",
  "safety_class": "isolated_mutation",
  "surface_ids": ["wordpress-core-post-types", "wordpress-core-taxonomies", "wordpress-core-permalinks", "wordpress-core-posts", "wordpress-core-pages"],
  "operations": ["post-type-inventory", "post-status-inventory", "taxonomy-inventory", "term-fixture-matrix", "permalink-resolution", "post-list-rendering", "page-list-rendering", "post-editor-readiness", "page-editor-readiness"],
  "case_budget": 160,
  "duration_budget_seconds": 1200,
  "metadata": { "kind": "wordpress-core-fuzz", "wordpress_runner": "wp-codebox", "expected_artifact_role": "fuzz_report", "expected_artifact_semantic_key": "fuzz.report", "readiness": { "level": "executable", "coverage_contract": "WordPress Core post type, status, taxonomy, term, and permalink coverage is executable as a isolated_mutation fuzz workload for post-type-inventory, post-status-inventory, taxonomy-inventory, term-fixture-matrix, permalink-resolution, post-list-rendering, page-list-rendering, post-editor-readiness, page-editor-readiness. Proven status still requires reviewer-facing run artifacts and gap reports.", "upstream_blockers": ["reviewer-facing fuzz run artifacts and gap reports are required before proven status"] } },
  "target": { "type": "wordpress-core", "component": "wordpress-develop" },
  "workload": { "runner": "wp-codebox", "type": "declarative", "path": "${package.root}/manifests/fuzzer-profile.json", "entry": "content-types-taxonomies" },
  "cases": [
    {
      "case_id": "content-types-taxonomies:registration-and-resolution",
      "surface_ids": ["wordpress-core-post-types", "wordpress-core-taxonomies", "wordpress-core-permalinks", "wordpress-core-posts", "wordpress-core-pages"],
      "operations": ["post-type-inventory", "post-status-inventory", "taxonomy-inventory", "term-fixture-matrix", "permalink-resolution", "post-list-rendering", "page-list-rendering", "post-editor-readiness", "page-editor-readiness"],
      "phases": {
        "setup": [{ "command": "wordpress.run-php", "args": ["code=wp_insert_post(array('post_title'=>'Content fixture','post_status'=>'publish')); wp_insert_term('Core fixture','category');"] }],
        "action": [{ "command": "wordpress.runtime-discovery", "args": ["surface=content,editor"] }],
        "assert": [{ "command": "wordpress.collect-workload-result", "args": ["artifact=content_types_taxonomies"] }]
      },
      "artifacts": [{ "name": "content_types_taxonomies", "path": "content-types-taxonomies/content_types_taxonomies.json", "required": true, "metadata": { "semantic_key": "fuzz.report", "schema": "homeboy-rigs/wordpress-core-content-types-taxonomies/v1" } }],
      "metadata": { "safety_class": "isolated_mutation", "scenarios": ["posts-list", "post-editor", "pages-list", "page-editor", "frontend-post-render", "frontend-page-render"], "skipped_reason_codes": ["destructive_bulk_action", "nonce_required", "permission_boundary"] }
    }
  ],
  "limits": { "max_cases": 160, "max_duration_seconds": 1200 },
  "coverage": { "surface_ids": ["wordpress-core-post-types", "wordpress-core-taxonomies", "wordpress-core-permalinks", "wordpress-core-posts", "wordpress-core-pages"], "operations": ["post-type-inventory", "post-status-inventory", "taxonomy-inventory", "term-fixture-matrix", "permalink-resolution", "post-list-rendering", "page-list-rendering", "post-editor-readiness", "page-editor-readiness"] },
  "artifacts": { "expected": [{ "name": "content_types_taxonomies", "role": "fuzz_report", "semantic_key": "fuzz.report", "required": true, "schema": "homeboy-rigs/wordpress-core-content-types-taxonomies/v1" }] }
}
