{
  "schema": "homeboy-rigs/gutenberg-fuzzer-profile/v1",
  "property": "WordPress/gutenberg",
  "description": "Rig-owned Gutenberg fuzzer profile analogous to Woo full-surface coverage. It composes REST route coverage, wp-admin/editor page coverage, block editor load/action probes, DB query/profile hooks, external HTTP guardrails, and coverage-gap reporting without adding Gutenberg-specific logic to Homeboy core or Homeboy Extensions.",
  "source_manifests": {
    "full_surface": "manifests/full-surface-coverage.json",
    "api_db_lab_cell": "manifests/api-db-lab-cell.json",
    "rest_routes": "manifests/rest-route-coverage.json",
    "rest_budgets": "manifests/rest-route-budgets.json",
    "fixtures": "manifests/performance-fixtures.json"
  },
  "execution": {
    "fuzz_rig": "gutenberg-api-route-inventory",
    "fuzz_workloads": [
      "gutenberg-rest-route-fuzz",
      "gutenberg-rest-request-cases-fuzz",
      "gutenberg-admin-page-coverage",
      "block-editor-browser-coverage",
      "site-editor-browser-coverage",
      "block-rendering-coverage",
      "frontend-rendering-request-coverage",
      "gutenberg-db-inventory-fuzz",
      "gutenberg-rest-db-query-profile-fuzz",
      "gutenberg-hooks-options-inventory",
      "gutenberg-editor-performance-observation",
      "gutenberg-external-http-guardrail-fuzz",
      "gutenberg-notes-attachment-corpus"
    ]
  },
  "surfaces": {
    "rest_route_coverage": {
      "workloads": ["gutenberg-rest-route-fuzz", "gutenberg-rest-request-cases-fuzz"],
      "target_manifest": "manifests/rest-route-coverage.json",
      "namespaces": ["wp/v2", "__experimental"],
      "permission_matrix": "Authenticated editor cases plus unauthenticated 401/403 boundary cases for protected editor routes.",
      "gap_rule": "Report registered Gutenberg-facing routes that do not have generated safe request cases or expected permission-boundary cases."
    },
    "wp_admin_editor_pages": {
      "fuzz_workloads": ["gutenberg-admin-page-coverage", "block-editor-browser-coverage", "site-editor-browser-coverage"],
      "scenario_sources": ["browser-scenarios/post_editor.json", "browser-scenarios/site_editor.json", "browser-scenarios/template_editor.json", "browser-scenarios/patterns.json"],
      "skipped_reason_codes": ["install_update_import_export_screen", "nonce_action_url", "unsafe_query_arg_action", "unsafe_query_arg_action2", "unsafe_query_arg_delete", "unsafe_query_arg_trash", "unsafe_query_arg_untrash", "unsafe_query_arg_activate", "unsafe_query_arg_deactivate", "unsafe_query_arg_reset"],
      "gap_rule": "Report target scenarios missing admin enumeration, browser request coverage artifacts, skipped/destructive reason codes, or readiness steps."
    },
    "block_editor_load_action_probes": {
      "scenario_files": [
        "browser-scenarios/post_editor.json",
        "browser-scenarios/site_editor.json",
        "browser-scenarios/template_editor.json",
        "browser-scenarios/patterns.json"
      ],
      "captures": ["steps", "console", "errors", "network", "html", "screenshot", "dom-snapshot"],
      "gap_rule": "Report editor screens that load but produce failed browser actions, browser errors, or no request coverage."
    },
    "block_notes_attachment_persistence": {
      "workloads": ["gutenberg-notes-attachment-corpus"],
      "corpus": "fuzz/gutenberg-notes-attachment-corpus.json#metadata/corpus_cases",
      "trace_workload": "bench/notes-unsaved-attachment.trace.mjs",
      "gap_rule": "Report declared Block Notes attachment cases without case-level execution, replay, and result-envelope artifacts."
    },
    "frontend_rendering_request_coverage": {
      "workloads": ["frontend-rendering-request-coverage"],
      "scenario_sources": ["browser-scenarios/frontend_rendering.json"],
      "captures": ["network", "request-coverage", "html", "screenshot", "dom-snapshot"],
      "gap_rule": "Report fixture frontend pages or dynamic block rendering requests missing browser request coverage artifacts."
    },
    "db_query_profile_hooks": {
      "workloads": ["gutenberg-db-inventory-fuzz", "gutenberg-rest-db-query-profile-fuzz"],
      "budget_manifest": "manifests/rest-route-budgets.json",
      "attribution": ["request_case_id", "route", "method", "query_type", "table", "stack_summary", "caller_summary"],
      "option_prefixes": ["_transient_gutenberg_", "gutenberg_", "wporg_patterns_", "wporg_block_directory_"],
      "postmeta_keys": ["_wp_page_template", "_wp_block_editor_context", "_wp_pattern_sync_status", "_wp_navigation_post_origin", "_wp_ignored_hooked_blocks", "footnotes"],
      "entity_types": ["wp_block", "wp_global_styles", "wp_navigation", "wp_template", "wp_template_part", "wp_pattern_category"],
      "lab_cell_contract": "manifests/api-db-lab-cell.json",
      "profile_contract": {
        "artifact_schema": "homeboy/wordpress-rest-db-query-profile/v1",
        "required_route_classes": ["editor-rest", "block-directory", "patterns", "global-styles", "block-renderer"],
        "required_fields": ["route", "method", "status", "query_count", "query_time_ms", "slowest_queries", "duplicate_query_groups"],
        "budget_fields": ["max_queries", "max_query_time_ms", "max_duplicate_query_groups"]
      },
      "gap_rule": "Report covered routes without query profiles, missing query attribution groups, missing option/postmeta/entity inventory, and query profiles that exceed Gutenberg route budgets."
    },
    "runtime_hook_option_inventory": {
      "workloads": ["gutenberg-hooks-options-inventory"],
      "artifact_schema": "homeboy/gutenberg-runtime-state-coverage/v1",
      "inventory_targets": {
        "hooks": ["registered Gutenberg actions", "registered Gutenberg filters", "block editor preload filters", "block renderer filters", "pattern directory filters"],
        "options": ["gutenberg experiments", "editor settings", "global styles", "block directory cache", "pattern directory cache"],
        "postmeta": ["template state", "template part state", "global styles revisions", "navigation state", "notes unsaved attachment state"],
        "cron_state": ["wp_scheduled_delete", "wp_update_plugins", "gutenberg-related scheduled events when present"],
        "transients": ["plugin/theme update cache", "block pattern remote cache", "block directory remote cache"]
      },
      "gap_rule": "Report missing hook, option, postmeta, transient, cron, or editor-state inventory sections rather than counting the runtime-state surface as covered."
    },
    "editor_performance_observation": {
      "workloads": ["gutenberg-editor-performance-observation"],
      "artifact_schema": "homeboy/gutenberg-performance-observation/v1",
      "contracts": {
        "post_editor": ["ready_time_ms", "rest_preload_hits", "rest_request_count", "asset_request_count", "long_task_total_ms", "console_error_count"],
        "site_editor": ["ready_time_ms", "rest_preload_hits", "rest_request_count", "global_styles_request_count", "template_request_count", "long_task_total_ms"],
        "block_rendering": ["rendered_block_count", "block_renderer_request_count", "server_render_time_ms", "query_count", "cache_hit_count"],
        "pattern_preview": ["preview_iframe_count", "fixture_asset_request_count", "unique_fixture_asset_count", "preview_ready_time_ms", "long_task_total_ms"],
        "notes_unsaved_attachment": ["attachment_upload_state", "autosave_request_count", "editor_notice_count", "unsaved_attachment_recovery_state"]
      },
      "gap_rule": "Report editor, Site Editor, block-rendering, pattern-preview, and notes-unsaved-attachment observations missing summary fields or artifact refs."
    },
    "server_request_guardrails": {
      "workloads": ["gutenberg-external-http-guardrail-fuzz"],
      "allowed_hosts": ["api.wordpress.org"],
      "synthetic_probe_hosts": ["patterns.wordpress.org"],
      "expectations": {
        "block_network": true,
        "allowed_host_behavior": "Requests to api.wordpress.org are captured and classified as approved.",
        "unapproved_host_behavior": "Requests to patterns.wordpress.org are captured as blocked synthetic guardrail probes.",
        "real_external_service_calls_allowed": false,
        "required_artifact_fields": ["approved_hosts", "blocked_hosts", "samples", "unexpected_allowed_hosts", "network_side_effects"]
      },
      "gap_rule": "Report unapproved outbound hosts touched by Gutenberg editor/library probes."
    }
  },
  "artifact_summaries": {
    "runtime_state": {
      "artifact": "gutenberg-hooks-options-inventory/gutenberg_runtime_state.json",
      "semantic_key": "fuzz.report",
      "required_sections": ["hooks", "options", "postmeta", "templates", "patterns", "cron", "transients", "editor_state"]
    },
    "db_query_profile": {
      "artifact": "rest-db-query-profile/rest_db_query_profile.json",
      "semantic_key": "fuzz.report",
      "required_sections": ["routes", "query_counts", "slowest_queries", "duplicate_query_groups", "budget_regressions"]
    },
    "external_http_guardrail": {
      "artifact": "gutenberg-external-http-guardrail/external_http_guardrail.json",
      "semantic_key": "fuzz.report",
      "required_sections": ["approved_hosts", "blocked_hosts", "unexpected_allowed_hosts", "samples"]
    },
    "performance_observation": {
      "artifact": "gutenberg-editor-performance-observation/gutenberg_performance_observation.json",
      "semantic_key": "fuzz.report",
      "required_sections": ["post_editor", "site_editor", "block_rendering", "pattern_preview", "notes_unsaved_attachment", "external_http_guardrail"]
    }
  },
  "coverage_gap_report": {
    "schema": "homeboy-rigs/gutenberg-fuzzer-coverage-gap/v1",
    "inputs": [
      "REST route inventory artifact",
      "generated REST request case artifact",
      "REST DB query profile artifact",
      "DB inventory artifact",
      "external HTTP guardrail artifact",
      "browser request coverage artifact",
      "runtime state inventory artifact",
      "performance observation summary artifact"
    ],
    "sections": [
      "rest_routes_without_cases",
      "permission_boundaries_without_cases",
      "admin_editor_scenarios_without_browser_coverage",
      "admin_pages_skipped_without_reason_codes",
      "frontend_rendering_scenarios_without_browser_coverage",
      "covered_routes_without_query_profiles",
      "queries_without_attribution",
      "options_postmeta_or_entities_without_inventory",
      "missing_runtime_state_inventory_sections",
      "missing_performance_observation_sections",
      "routes_without_permission_boundary_cases",
      "queries_without_table_or_key_attribution",
      "entities_without_state_artifacts",
      "budget_regressions",
      "unapproved_external_hosts",
      "unexpected_allowed_external_hosts",
      "open_fixture_or_primitive_gaps"
    ]
  }
}
