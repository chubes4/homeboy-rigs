{
  "schema": "homeboy/fuzz-workload/v1",
  "id": "gutenberg-db-inventory-fuzz",
  "label": "Gutenberg database inventory coverage",
  "safety_class": "read_only",
  "surface_ids": ["wordpress-database", "gutenberg-fixture-state"],
  "operations": ["database-inventory", "fixture-state-classification", "option-prefix-inventory", "postmeta-key-inventory", "gutenberg-entity-inventory"],
  "case_budget": 20,
  "duration_budget_seconds": 300,
  "metadata": {
    "kind": "wordpress-plugin-fuzz",
    "wordpress_runner": "wp-codebox",
    "generic_primitive": { "command": "wordpress.inventory-database", "status": "supported" },
    "expected_artifact_role": "fuzz_report",
    "expected_artifact_semantic_key": "fuzz.report",
    "readiness": { "level": "executable", "coverage_contract": "Database inventory runs through the canonical Codebox primitive with Gutenberg option prefixes, postmeta keys, entity types, and artifact expectations.", "upstream_blockers": ["reviewer-facing execution artifacts are required before proven status"] }
  },
  "target": { "type": "wordpress-plugin", "slug": "gutenberg", "component": "gutenberg" },
  "workload": { "runner": "wp-codebox", "type": "declarative", "command": "wordpress.inventory-database" },
  "cases": [
    {
      "case_id": "gutenberg-db-inventory-fuzz:default",
      "surface_ids": ["wordpress-database", "gutenberg-fixture-state"],
      "operations": ["database-inventory", "fixture-state-classification", "option-prefix-inventory", "postmeta-key-inventory", "gutenberg-entity-inventory"],
      "phases": {
        "setup": [{ "command": "wordpress.ensure-plugin-active", "args": ["plugin=gutenberg/gutenberg.php"] }],
        "action": [{ "command": "wordpress.inventory-database", "args": ["option_prefixes=gutenberg_,wp_global_styles", "postmeta_keys=_wp_block_template"] }],
        "assert": [{ "command": "wordpress.collect-workload-result", "args": ["artifact=db_inventory"] }]
      },
      "artifacts": [{ "name": "db_inventory", "path": "db-inventory/db_inventory.json", "required": true, "metadata": { "semantic_key": "fuzz.report" } }],
      "metadata": { "safety_class": "read_only" }
    }
  ],
  "limits": { "max_cases": 20, "max_duration_seconds": 300 },
  "coverage": { "surface_ids": ["wordpress-database", "gutenberg-fixture-state"], "operations": ["database-inventory", "fixture-state-classification", "option-prefix-inventory", "postmeta-key-inventory", "gutenberg-entity-inventory"] },
  "artifacts": { "expected": [{ "name": "db_inventory", "role": "fuzz_report", "semantic_key": "fuzz.report", "required": true }] }
}
