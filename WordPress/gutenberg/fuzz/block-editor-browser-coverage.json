{
  "schema": "homeboy/fuzz-workload/v1",
  "id": "block-editor-browser-coverage",
  "label": "Gutenberg block editor browser coverage",
  "safety_class": "isolated_mutation",
  "surface_ids": ["gutenberg-block-editor", "wordpress-admin-pages", "browser-requests"],
  "operations": ["editor-page-load", "block-editor-action-probe", "browser-request-coverage"],
  "case_budget": 24,
  "duration_budget_seconds": 900,
  "metadata": {
    "kind": "wordpress-plugin-fuzz",
    "wordpress_runner": "wp-codebox",
    "fixture": "${package.root}/fixtures/browser-coverage.php",
    "expected_artifact_role": "fuzz_report",
    "expected_artifact_semantic_key": "fuzz.report", "readiness": { "level": "executable", "coverage_contract": "Gutenberg block editor browser coverage is executable as a isolated_mutation fuzz workload for editor-page-load, block-editor-action-probe, browser-request-coverage. Proven status still requires reviewer-facing run artifacts and gap reports.", "upstream_blockers": ["reviewer-facing fuzz run artifacts and gap reports are required before proven status"] }
  },
  "target": { "type": "wordpress-plugin", "slug": "gutenberg", "component": "gutenberg" },
  "workload": {
    "runner": "wp-codebox",
    "type": "declarative",
    "command": "wordpress.browser-scenario"
  },
  "cases": [
    {
      "case_id": "block-editor-browser-coverage:default",
      "surface_ids": ["gutenberg-block-editor", "wordpress-admin-pages", "browser-requests"],
      "operations": ["editor-page-load", "block-editor-action-probe", "browser-request-coverage"],
      "phases": {
        "setup": [{ "command": "wordpress.ensure-plugin-active", "args": ["plugin=gutenberg/gutenberg.php"] }, { "command": "wordpress.run-php", "args": ["code-file=${package.root}/fixtures/browser-coverage.php"] }],
        "action": [{ "command": "wordpress.browser-scenario", "args": ["scenario-json={\"auth\":\"wordpress-admin\",\"url\":\"/wp-admin/post-new.php\",\"steps\":[{\"kind\":\"navigate\",\"url\":\"/wp-admin/post-new.php\",\"waitFor\":\"load\"},{\"kind\":\"waitFor\",\"selector\":\"body\",\"timeout\":\"30s\"},{\"kind\":\"screenshot\",\"name\":\"gutenberg-post-editor\"}],\"capture\":[\"network\",\"screenshot\"]}"] }],
        "assert": [{ "command": "wordpress.collect-workload-result", "args": ["artifact=block_editor_browser_coverage"] }]
      },
      "artifacts": [{ "name": "block_editor_browser_coverage", "path": "block-editor-browser-coverage/browser_request_coverage.json", "required": true, "metadata": { "semantic_key": "fuzz.report" } }],
      "metadata": { "safety_class": "isolated_mutation" }
    }
  ],
  "limits": { "max_cases": 24, "max_duration_seconds": 900 },
  "coverage": { "surface_ids": ["gutenberg-block-editor", "wordpress-admin-pages", "browser-requests"], "operations": ["editor-page-load", "block-editor-action-probe", "browser-request-coverage"] },
  "artifacts": { "expected": [{ "name": "block_editor_browser_coverage", "role": "fuzz_report", "semantic_key": "fuzz.report", "required": true }] }
}
