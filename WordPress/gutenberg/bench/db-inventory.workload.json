{
  "id": "db-inventory",
  "source": "config",
  "run": [
    {
      "type": "db-inventory",
      "metric-prefix": "db_inventory",
      "include-columns": true,
      "include-indexes": true,
      "include-row-counts": true,
      "option_prefixes": [
        "_transient_gutenberg_",
        "gutenberg_",
        "wporg_patterns_",
        "wporg_block_directory_"
      ],
      "postmeta_keys": [
        "_wp_page_template",
        "_wp_block_editor_context",
        "_wp_pattern_sync_status",
        "_wp_navigation_post_origin",
        "_wp_ignored_hooked_blocks",
        "footnotes"
      ],
      "post_types": [
        "post",
        "page",
        "wp_block",
        "wp_global_styles",
        "wp_navigation",
        "wp_template",
        "wp_template_part"
      ],
      "taxonomy_terms": [
        "wp_pattern_category"
      ]
    }
  ],
  "metadata": {
    "runner": "wp-codebox",
    "workload": "db-inventory",
    "coverage_shape": "Gutenberg fixture database table, row, column, and index inventory",
    "manifest": "manifests/full-surface-coverage.json",
    "inventory_contract": "table, row, column, index, Gutenberg option prefix, postmeta key, block/editor/template/pattern post type, and pattern taxonomy inventory"
  }
}
