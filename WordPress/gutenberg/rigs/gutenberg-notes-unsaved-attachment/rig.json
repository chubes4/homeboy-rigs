{
  "id": "gutenberg-notes-unsaved-attachment",
  "description": "Gutenberg Block Notes unsaved attachment repro rig for WordPress/gutenberg#72717.",
  "components": {
    "gutenberg": {
      "path": "${env.HOMEBOY_RIG_COMPONENT_PATH__GUTENBERG_NOTES_UNSAVED_ATTACHMENT__GUTENBERG}",
      "branch": "trunk"
    }
  },
  "resources": {
    "exclusive": [
      "gutenberg-notes-unsaved-attachment:${env.HOMEBOY_SETTINGS_GUTENBERG_NOTES_NAMESPACE}"
    ],
    "paths": [
      "${components.gutenberg.path}"
    ]
  },
  "lifecycle": {
    "cleanup": {
      "schema": "homeboy/resource-cleanup-intent/v1",
      "intent": "dry_run",
      "ownership": {
        "dry_run": {
          "owner": "wp-codebox-runner-namespace",
          "declared_by": "homeboy-rigs",
          "reason": "WP Codebox sandbox teardown and the runner namespace own runtime cleanup; component checkouts are user-owned."
        }
      }
    }
  },
  "trace": {
    "default_component": "gutenberg"
  },
  "trace_workloads": {
    "nodejs": [
      {
        "path": "${package.root}/bench/notes-unsaved-attachment.trace.mjs",
        "check_groups": [],
        "port_range_size": 1,
        "trace_default_phase_preset": "browser-notes-repro",
        "trace_phase_presets": {
          "browser-notes-repro": [
            "start:scenario.start",
            "recipe:wp_codebox.recipe.start",
            "probe:browser.probe.ready",
            "metrics:notes-unsaved-attachment.metrics.ready"
          ]
        },
        "trace_span_metadata": {
          "phase.recipe_to_probe": {
            "category": "browser_probe",
            "blocking": true
          },
          "phase.probe_to_metrics": {
            "category": "artifact_extraction",
            "blocking": true
          }
        }
      }
    ]
  },
  "trace_profiles": {
    "smoke": {
      "scenario": "notes-unsaved-attachment",
      "settings": {
        "gutenberg_notes_case": "orphan"
      }
    },
    "orphan": {
      "scenario": "notes-unsaved-attachment",
      "settings": {
        "gutenberg_notes_case": "orphan"
      }
    },
    "saved-anchor": {
      "scenario": "notes-unsaved-attachment",
      "settings": {
        "gutenberg_notes_case": "saved-anchor"
      }
    },
    "autosave-anchor": {
      "scenario": "notes-unsaved-attachment",
      "settings": {
        "gutenberg_notes_case": "autosave-anchor"
      }
    },
    "live-create": {
      "scenario": "notes-unsaved-attachment",
      "settings": {
        "gutenberg_notes_case": "live-create"
      }
    },
    "dirty-live-create": {
      "scenario": "notes-unsaved-attachment",
      "settings": {
        "gutenberg_notes_case": "dirty-live-create"
      }
    },
    "dirty-sibling-live-create": {
      "scenario": "notes-unsaved-attachment",
      "settings": {
        "gutenberg_notes_case": "dirty-sibling-live-create"
      }
    },
    "dirty-structural-live-create": {
      "scenario": "notes-unsaved-attachment",
      "settings": {
        "gutenberg_notes_case": "dirty-structural-live-create"
      }
    },
    "nested-live-create": {
      "scenario": "notes-unsaved-attachment",
      "settings": {
        "gutenberg_notes_case": "nested-live-create"
      }
    },
    "double-live-create": {
      "scenario": "notes-unsaved-attachment",
      "settings": {
        "gutenberg_notes_case": "double-live-create"
      }
    }
  },
  "pipeline": {
    "check": [
      {
        "kind": "requirement",
        "label": "Gutenberg checkout exists",
        "file": "${components.gutenberg.path}/gutenberg.php",
        "component": "gutenberg",
        "component_path_contains": "gutenberg",
        "remediation": "Pass homeboy trace --path /path/to/gutenberg or update components.gutenberg.path before running gutenberg-notes-unsaved-attachment."
      }
    ],
    "down": []
  }
}
