{
  "id": "gutenberg-pattern-preview-assets",
  "description": "Gutenberg pattern preview asset fan-out rig for reproducing WordPress/gutenberg#68979 and the request-spike symptoms discussed in WordPress/gutenberg#71547.",
  "components": {
    "gutenberg": {
      "path": "${env.HOMEBOY_RIG_COMPONENT_PATH__GUTENBERG_PATTERN_PREVIEW_ASSETS__GUTENBERG}",
      "branch": "trunk"
    }
  },
  "resources": {
    "exclusive": [
      "gutenberg-pattern-preview-assets:${env.HOMEBOY_SETTINGS_GUTENBERG_PATTERN_ASSETS_NAMESPACE}"
    ],
    "paths": [
      "${components.gutenberg.path}"
    ]
  },
  "lifecycle": {
    "cleanup": {
      "intent": "external",
      "reason": "WP Codebox sandbox teardown and the runner namespace own runtime cleanup; component checkouts are user-owned."
    }
  },
  "trace": {
    "default_component": "gutenberg"
  },
  "trace_workloads": {
    "nodejs": [
      {
        "path": "${package.root}/bench/pattern-preview-assets.trace.mjs",
        "check_groups": [],
        "port_range_size": 1,
        "trace_default_phase_preset": "browser-waterfall",
        "trace_phase_presets": {
          "browser-waterfall": [
            "start:scenario.start",
            "recipe:wp_codebox.recipe.start",
            "probe:browser.probe.ready",
            "metrics:pattern-assets.metrics.ready"
          ]
        },
        "trace_span_metadata": {
          "phase.recipe_to_probe": {
            "category": "browser_probe",
            "blocking": true
          },
          "phase.probe_to_metrics": {
            "category": "artifact_extraction",
            "blocking": true
          }
        }
      }
    ]
  },
  "trace_profiles": {
    "smoke": [
      "pattern-preview-assets"
    ]
  },
  "pipeline": {
    "check": [
      {
        "kind": "requirement",
        "label": "Gutenberg checkout exists",
        "file": "${components.gutenberg.path}/gutenberg.php",
        "component": "gutenberg",
        "component_path_contains": "gutenberg",
        "remediation": "Pass homeboy trace --path /path/to/gutenberg or update components.gutenberg.path before running gutenberg-pattern-preview-assets."
      }
    ],
    "down": []
  }
}
