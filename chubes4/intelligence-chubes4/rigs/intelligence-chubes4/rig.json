{
  "id": "intelligence-chubes4",
  "description": "intelligence-chubes4 site runtime — points the live WordPress plugin symlinks at the worktrees we're testing. Edit components.<id>.path to switch which worktree (or primary checkout) is mounted, then `rig up`.",
  "components": {
    "intelligence": {
      "path": "~/Developer/intelligence@feat-search-observability",
      "branch": "feat-search-observability"
    }
  },
  "symlinks": [
    {
      "link": "~/Studio/intelligence-chubes4/wp-content/plugins/intelligence",
      "target": "${components.intelligence.path}"
    }
  ],
  "pipeline": {
    "up": [
      { "kind": "symlink", "op": "ensure" }
    ],
    "check": [
      { "kind": "symlink", "op": "verify" }
    ],
    "down": []
  }
}
